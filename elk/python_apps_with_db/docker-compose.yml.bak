services:
  server:
    build:
      context: ./server
      dockerfile: Dockerfile
    ports:
      - "5000:5000"
    environment:
      - DB_HOST=db
      - DB_USER=postgres
      - DB_NAME=postgres
      - DB_PASSWORD=postgres

  client:
    build:
      context: ./client
      dockerfile: Dockerfile
    environment:
      - SERVER_URL=http://server:5000
    depends_on:
      - server
